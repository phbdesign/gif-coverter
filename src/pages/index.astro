---
import Layout from "../layouts/Layout.astro";

// ffmpeg.wasm é servido pela MESMA ORIGEM (evita o bloqueio de scripts externos
// via CSP do Webflow Cloud). Os arquivos vêm do npm e são copiados para
// /public/ffmpeg durante o build (ver astro.config.mjs). `ffmpegBase` respeita
// o mount path configurado.
const base = import.meta.env.BASE_URL || "/";
const b = base.endsWith("/") ? base.slice(0, -1) : base;
const ffmpegBase = b + "/ffmpeg";
---

<Layout>
  <main class="page">
    <div class="container">
      <header class="hero">
        <div class="badge">
          <span class="dot"></span> Otimizado para Power BI
        </div>
        <h1>Vídeo <span class="arrow">→</span> GIF</h1>
        <p class="subtitle">
          Transforme vídeos em GIFs leves, prontos para seus dashboards do
          Power BI. A conversão acontece 100% no seu navegador — nenhum
          arquivo é enviado para servidores.
        </p>
      </header>

      <!-- Área de upload -->
      <label id="dropzone" class="dropzone" for="file-input" tabindex="0">
        <input id="file-input" type="file" accept="video/*" multiple hidden />
        <div class="dz-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="34" height="34" fill="none"
            stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
            stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="17 8 12 3 7 8" />
            <line x1="12" y1="3" x2="12" y2="15" />
          </svg>
        </div>
        <div class="dz-title">Arraste vídeos aqui ou clique para selecionar</div>
        <div class="dz-hint">MP4, MOV, WebM, MKV e outros · 1 ou vários arquivos</div>
      </label>

      <!-- Lista de arquivos -->
      <section id="file-section" class="block hidden">
        <div class="block-label">
          Arquivos selecionados <span id="file-count" class="count">0</span>
        </div>
        <ul id="file-list" class="file-list"></ul>
      </section>

      <!-- Presets -->
      <section class="block">
        <div class="block-label">Qualidade do GIF</div>
        <div class="preset-grid" id="preset-grid" role="radiogroup" aria-label="Qualidade do GIF">
          <button class="preset" data-preset="compacto" role="radio" aria-checked="false" type="button">
            <div class="preset-name">Compacto</div>
            <div class="preset-spec">400&nbsp;px · 10&nbsp;fps</div>
            <div class="preset-desc">Menor tamanho de arquivo. Ideal para tiles pequenos e para incorporar o GIF direto no relatório.</div>
          </button>
          <button class="preset is-selected" data-preset="equilibrado" role="radio" aria-checked="true" type="button">
            <div class="preset-tag">Recomendado</div>
            <div class="preset-name">Equilibrado</div>
            <div class="preset-spec">560&nbsp;px · 12&nbsp;fps</div>
            <div class="preset-desc">Melhor relação entre tamanho e qualidade. Funciona bem na maioria dos dashboards.</div>
          </button>
          <button class="preset" data-preset="nitido" role="radio" aria-checked="false" type="button">
            <div class="preset-name">Nítido</div>
            <div class="preset-spec">720&nbsp;px · 15&nbsp;fps</div>
            <div class="preset-desc">Mais definição e fluidez. Para visuais maiores — gera arquivos maiores.</div>
          </button>
        </div>
      </section>

      <!-- Ação -->
      <button id="convert-btn" class="btn-primary" type="button" disabled>
        <span class="btn-label">Converter para GIF</span>
        <span class="spinner" aria-hidden="true"></span>
      </button>
      <div id="global-status" class="global-status" role="status"></div>

      <!-- Resultados -->
      <section id="results-section" class="block hidden">
        <div class="results-head">
          <div class="block-label">Resultados</div>
          <button id="download-all" class="btn-ghost" type="button">Baixar todos</button>
        </div>
        <div id="results" class="results"></div>
      </section>

      <footer class="foot">
        <strong>Dica para Power BI:</strong> insira o GIF com o visual
        <em>“Image”</em> apontando para a URL do arquivo hospedado, ou use um
        visual de conteúdo HTML. Quanto menor o GIF, mais rápido o dashboard
        carrega — comece pelo preset <em>Equilibrado</em> e use o
        <em>Compacto</em> se precisar de arquivos ainda mais leves.
      </footer>
    </div>
  </main>
</Layout>

<style is:global>
  :root {
    --bg: #f6f7fb;
    --ink: #1a1c25;
    --muted: #6b7280;
    --line: #e6e8ef;
    --card: #ffffff;
    --accent: #6366f1;
    --accent-2: #8b5cf6;
    --accent-soft: #eef0fe;
    --ok: #16a34a;
    --err: #dc2626;
    --radius: 18px;
    --shadow: 0 10px 30px rgba(34, 38, 64, 0.07);
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto,
      Helvetica, Arial, sans-serif;
  }

  body {
    color: var(--ink);
    background:
      radial-gradient(1100px 520px at 50% -180px, #eceefe 0%, rgba(236, 238, 254, 0) 70%),
      var(--bg);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  .page {
    display: flex;
    justify-content: center;
    padding: 40px 20px 64px;
  }
  .container {
    width: 100%;
    max-width: 760px;
  }

  /* Hero */
  .hero {
    text-align: center;
    margin-bottom: 28px;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 13px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 18px;
  }
  .badge .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.18);
  }
  h1 {
    font-size: 44px;
    line-height: 1.05;
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }
  h1 .arrow {
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding: 0 4px;
  }
  .subtitle {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.6;
    max-width: 520px;
    margin: 0 auto;
  }

  /* Dropzone */
  .dropzone {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
    padding: 44px 24px;
    background: var(--card);
    border: 2px dashed #cdd2e4;
    border-radius: var(--radius);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, transform 0.05s;
    box-shadow: var(--shadow);
    outline: none;
  }
  .dropzone:hover,
  .dropzone:focus-visible {
    border-color: var(--accent);
    background: #fbfbff;
  }
  .dropzone.is-drag {
    border-color: var(--accent);
    background: var(--accent-soft);
    transform: scale(1.005);
  }
  .dz-icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    display: grid;
    place-items: center;
    color: var(--accent);
    background: var(--accent-soft);
    margin-bottom: 6px;
  }
  .dz-title {
    font-weight: 600;
    font-size: 16px;
  }
  .dz-hint {
    color: var(--muted);
    font-size: 13.5px;
  }

  /* Blocks */
  .block {
    margin-top: 26px;
  }
  .block-label {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
  }
  .count {
    display: inline-grid;
    place-items: center;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 999px;
    font-size: 12px;
    vertical-align: middle;
  }

  /* File list */
  .file-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .file-row {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 12px 14px;
  }
  .file-thumb {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--accent-soft);
    color: var(--accent);
    display: grid;
    place-items: center;
    flex: none;
  }
  .file-meta {
    min-width: 0;
    flex: 1;
  }
  .file-name {
    font-weight: 600;
    font-size: 14.5px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .file-sub {
    color: var(--muted);
    font-size: 12.5px;
    margin-top: 2px;
  }
  .file-remove {
    flex: none;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    padding: 6px;
    border-radius: 8px;
    line-height: 0;
    transition: background 0.15s, color 0.15s;
  }
  .file-remove:hover {
    background: #fdecec;
    color: var(--err);
  }

  /* Presets */
  .preset-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .preset {
    position: relative;
    text-align: left;
    background: var(--card);
    border: 1.5px solid var(--line);
    border-radius: 16px;
    padding: 16px 16px 18px;
    cursor: pointer;
    transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
    font: inherit;
    color: inherit;
  }
  .preset:hover {
    border-color: #c3c8e6;
  }
  .preset.is-selected {
    border-color: var(--accent);
    background: #fbfbff;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.14);
  }
  .preset-tag {
    position: absolute;
    top: -10px;
    left: 16px;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: 999px;
  }
  .preset-name {
    font-weight: 700;
    font-size: 16px;
  }
  .preset-spec {
    color: var(--accent);
    font-size: 12.5px;
    font-weight: 600;
    margin: 3px 0 8px;
  }
  .preset-desc {
    color: var(--muted);
    font-size: 12.5px;
    line-height: 1.5;
  }

  /* Buttons */
  .btn-primary {
    margin-top: 26px;
    width: 100%;
    border: none;
    border-radius: 14px;
    padding: 16px 20px;
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: filter 0.15s, opacity 0.15s, transform 0.05s;
    box-shadow: 0 10px 24px rgba(99, 102, 241, 0.28);
  }
  .btn-primary:hover:not(:disabled) {
    filter: brightness(1.05);
  }
  .btn-primary:active:not(:disabled) {
    transform: translateY(1px);
  }
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    box-shadow: none;
  }
  .btn-primary.is-busy {
    cursor: progress;
  }
  .btn-primary .spinner {
    display: none;
    width: 18px;
    height: 18px;
    border: 2.5px solid rgba(255, 255, 255, 0.45);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }
  .btn-primary.is-busy .spinner {
    display: inline-block;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .btn-ghost {
    border: 1px solid var(--line);
    background: var(--card);
    color: var(--ink);
    font: inherit;
    font-weight: 600;
    font-size: 13.5px;
    padding: 8px 14px;
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .btn-ghost:hover {
    border-color: var(--accent);
    background: #fbfbff;
  }

  .global-status {
    text-align: center;
    color: var(--muted);
    font-size: 13.5px;
    min-height: 20px;
    margin-top: 12px;
  }

  /* Results */
  .results-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .results {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .result-card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .result-preview {
    background:
      linear-gradient(45deg, #f0f1f6 25%, transparent 25%, transparent 75%, #f0f1f6 75%) 0 0/20px 20px,
      linear-gradient(45deg, #f0f1f6 25%, #fff 25%, #fff 75%, #f0f1f6 75%) 10px 10px/20px 20px,
      #fafbff;
    min-height: 150px;
    display: grid;
    place-items: center;
    padding: 10px;
  }
  .result-preview img {
    max-width: 100%;
    max-height: 220px;
    border-radius: 8px;
    display: block;
  }
  .result-body {
    padding: 12px 14px 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .result-name {
    font-weight: 600;
    font-size: 14px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .result-meta {
    color: var(--muted);
    font-size: 12.5px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .chip {
    background: var(--accent-soft);
    color: var(--accent);
    padding: 2px 8px;
    border-radius: 999px;
    font-weight: 600;
  }
  .result-progress {
    height: 8px;
    background: #eef0f6;
    border-radius: 999px;
    overflow: hidden;
  }
  .result-progress > span {
    display: block;
    height: 100%;
    width: 0%;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    transition: width 0.2s;
  }
  .result-status {
    font-size: 12.5px;
    color: var(--muted);
  }
  .result-status.is-error {
    color: var(--err);
  }
  .btn-download {
    text-align: center;
    text-decoration: none;
    border: none;
    border-radius: 10px;
    padding: 10px 12px;
    font-weight: 700;
    font-size: 13.5px;
    color: #fff;
    background: var(--ink);
    cursor: pointer;
    transition: filter 0.15s;
  }
  .btn-download:hover {
    filter: brightness(1.15);
  }

  .foot {
    margin-top: 34px;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.65;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 16px 18px;
  }
  .foot strong {
    color: var(--ink);
  }

  .hidden {
    display: none !important;
  }

  @media (max-width: 560px) {
    h1 {
      font-size: 36px;
    }
    .preset-grid {
      grid-template-columns: 1fr;
    }
    .results {
      grid-template-columns: 1fr;
    }
  }
</style>

<!-- Motor de conversão (ffmpeg.wasm) — servido pela própria origem do app -->
<script is:inline src={`${ffmpegBase}/ffmpeg.js`}></script>

<script define:vars={{ ffmpegBase }}>
  (function () {
    "use strict";

    // ---- Presets otimizados para Power BI ----
    var PRESETS = {
      compacto: { label: "Compacto", width: 400, fps: 10, colors: 64 },
      equilibrado: { label: "Equilibrado", width: 560, fps: 12, colors: 128 },
      nitido: { label: "Nítido", width: 720, fps: 15, colors: 200 },
    };

    // Helpers que substituem o @ffmpeg/util (que não expõe um global confiável).
    function toBlobURL(url, mime) {
      return fetch(url)
        .then(function (r) {
          if (!r.ok) throw new Error("Falha ao baixar " + url + " (HTTP " + r.status + ")");
          return r.arrayBuffer();
        })
        .then(function (buf) {
          return URL.createObjectURL(new Blob([buf], { type: mime }));
        });
    }
    function fetchFile(file) {
      return file.arrayBuffer().then(function (buf) {
        return new Uint8Array(buf);
      });
    }

    // ---- Estado ----
    var files = [];
    var idSeq = 0;
    var selectedPreset = "equilibrado";
    var ffmpeg = null;
    var ffmpegLoadingPromise = null;
    var currentProgressCb = null;
    var converting = false;
    var results = []; // { name, blob, url }

    // ---- Elementos ----
    var dropzone = document.getElementById("dropzone");
    var fileInput = document.getElementById("file-input");
    var fileSection = document.getElementById("file-section");
    var fileListEl = document.getElementById("file-list");
    var fileCountEl = document.getElementById("file-count");
    var presetGrid = document.getElementById("preset-grid");
    var convertBtn = document.getElementById("convert-btn");
    var globalStatus = document.getElementById("global-status");
    var resultsSection = document.getElementById("results-section");
    var resultsEl = document.getElementById("results");
    var downloadAllBtn = document.getElementById("download-all");

    // ---- Utilidades ----
    function formatBytes(n) {
      if (!n && n !== 0) return "";
      if (n < 1024) return n + " B";
      if (n < 1024 * 1024) return (n / 1024).toFixed(0) + " KB";
      return (n / (1024 * 1024)).toFixed(1) + " MB";
    }
    function formatDuration(s) {
      if (!s || !isFinite(s)) return "";
      var m = Math.floor(s / 60);
      var sec = Math.round(s % 60);
      return m + ":" + (sec < 10 ? "0" : "") + sec;
    }
    function guessExt(name) {
      var m = /\.([a-z0-9]+)$/i.exec(name || "");
      return m ? "." + m[1].toLowerCase() : ".mp4";
    }
    function baseName(name) {
      return (name || "video").replace(/\.[^.]+$/, "");
    }
    function isVideo(file) {
      if (file.type && file.type.indexOf("video/") === 0) return true;
      return /\.(mp4|mov|webm|mkv|avi|m4v|ogv|mpg|mpeg|3gp|flv|wmv)$/i.test(file.name || "");
    }

    function getVideoMeta(file) {
      return new Promise(function (resolve) {
        var v = document.createElement("video");
        var url = URL.createObjectURL(file);
        var done = false;
        function finish(meta) {
          if (done) return;
          done = true;
          URL.revokeObjectURL(url);
          resolve(meta);
        }
        v.preload = "metadata";
        v.muted = true;
        v.onloadedmetadata = function () {
          finish({ width: v.videoWidth, height: v.videoHeight, duration: v.duration });
        };
        v.onerror = function () {
          finish({ width: 0, height: 0, duration: 0 });
        };
        setTimeout(function () {
          finish({ width: 0, height: 0, duration: 0 });
        }, 8000);
        v.src = url;
      });
    }

    // ---- Carrega o ffmpeg.wasm (uma vez só) ----
    function loadFFmpeg(onStatus) {
      if (ffmpeg) return Promise.resolve(ffmpeg);
      if (ffmpegLoadingPromise) return ffmpegLoadingPromise;

      ffmpegLoadingPromise = (async function () {
        if (!window.FFmpegWASM || !window.FFmpegWASM.FFmpeg) {
          throw new Error("Não foi possível carregar o motor de conversão. Recarregue a página e tente novamente.");
        }
        var FFmpeg = window.FFmpegWASM.FFmpeg;
        var inst = new FFmpeg();
        if (onStatus) onStatus("Preparando o motor de conversão (só na primeira vez)…");
        // Worker clássico é carregado pela lib na mesma origem (o publicPath vem
        // do <script src=".../ffmpeg/ffmpeg.js">). Core e wasm viram blobs
        // same-origin — sem classWorkerURL e sem depender de CDN externo.
        await inst.load({
          coreURL: await toBlobURL(ffmpegBase + "/ffmpeg-core.js", "text/javascript"),
          wasmURL: await toBlobURL(ffmpegBase + "/ffmpeg-core.wasm", "application/wasm"),
        });
        inst.on("progress", function (e) {
          if (currentProgressCb) currentProgressCb(e);
        });
        ffmpeg = inst;
        return inst;
      })();

      return ffmpegLoadingPromise;
    }

    // ---- Converte um arquivo ----
    async function convertOne(entry, onProgress, onStatus) {
      var ff = await loadFFmpeg(onStatus);
      var p = PRESETS[selectedPreset];

      var meta = await getVideoMeta(entry.file);
      var w = p.width;
      if (meta.width && meta.width > 0 && meta.width < w) w = meta.width;
      if (w % 2 !== 0) w -= 1;

      var inName = "in_" + entry.id + guessExt(entry.file.name);
      var outName = "out_" + entry.id + ".gif";

      if (onStatus) onStatus("Convertendo “" + entry.file.name + "”…");

      await ff.writeFile(inName, await fetchFile(entry.file));

      currentProgressCb = function (e) {
        var pct = Math.round((e && e.progress ? e.progress : 0) * 100);
        if (pct < 0) pct = 0;
        if (pct > 99) pct = 99;
        onProgress(pct);
      };

      var filter =
        "[0:v]fps=" + p.fps + ",scale=" + w + ":-2:flags=lanczos,split[a][b];" +
        "[a]palettegen=max_colors=" + p.colors + ":stats_mode=diff[p];" +
        "[b][p]paletteuse=dither=bayer:bayer_scale=5:diff_mode=rectangle";

      await ff.exec(["-i", inName, "-filter_complex", filter, "-loop", "0", outName]);
      currentProgressCb = null;

      var data = await ff.readFile(outName);
      try {
        await ff.deleteFile(inName);
        await ff.deleteFile(outName);
      } catch (e) {}

      var blob = new Blob([data], { type: "image/gif" });
      return { blob: blob, width: w };
    }

    // ---- Render: lista de arquivos ----
    var fileIconSvg =
      '<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8z"/><rect x="2" y="6" width="14" height="12" rx="2"/></svg>';
    var removeIconSvg =
      '<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';

    function renderFileList() {
      fileListEl.innerHTML = "";
      fileCountEl.textContent = String(files.length);
      if (files.length === 0) {
        fileSection.classList.add("hidden");
      } else {
        fileSection.classList.remove("hidden");
      }
      files.forEach(function (entry) {
        var li = document.createElement("li");
        li.className = "file-row";

        var thumb = document.createElement("div");
        thumb.className = "file-thumb";
        thumb.innerHTML = fileIconSvg;

        var meta = document.createElement("div");
        meta.className = "file-meta";
        var name = document.createElement("div");
        name.className = "file-name";
        name.textContent = entry.file.name;
        var sub = document.createElement("div");
        sub.className = "file-sub";
        sub.textContent = formatBytes(entry.file.size);
        meta.appendChild(name);
        meta.appendChild(sub);

        var rm = document.createElement("button");
        rm.className = "file-remove";
        rm.type = "button";
        rm.setAttribute("aria-label", "Remover " + entry.file.name);
        rm.innerHTML = removeIconSvg;
        rm.addEventListener("click", function (ev) {
          ev.preventDefault();
          ev.stopPropagation();
          files = files.filter(function (f) {
            return f.id !== entry.id;
          });
          renderFileList();
          updateConvertBtn();
        });

        li.appendChild(thumb);
        li.appendChild(meta);
        li.appendChild(rm);
        fileListEl.appendChild(li);

        // duração (assíncrono, só enriquece o subtítulo)
        getVideoMeta(entry.file).then(function (m) {
          var parts = [formatBytes(entry.file.size)];
          if (m.width) parts.push(m.width + "×" + m.height);
          if (m.duration) parts.push(formatDuration(m.duration));
          sub.textContent = parts.join(" · ");
        });
      });
    }

    function addFiles(list) {
      var added = 0;
      for (var i = 0; i < list.length; i++) {
        var f = list[i];
        if (!isVideo(f)) continue;
        files.push({ id: ++idSeq, file: f });
        added++;
      }
      if (added > 0) {
        renderFileList();
        updateConvertBtn();
      } else if (list.length > 0) {
        flashStatus("Selecione arquivos de vídeo (MP4, MOV, WebM, etc.).");
      }
    }

    function flashStatus(msg) {
      globalStatus.textContent = msg;
      setTimeout(function () {
        if (globalStatus.textContent === msg) globalStatus.textContent = "";
      }, 4000);
    }

    function updateConvertBtn() {
      convertBtn.disabled = converting || files.length === 0;
      var label = convertBtn.querySelector(".btn-label");
      if (!converting) {
        label.textContent =
          files.length > 1
            ? "Converter " + files.length + " vídeos para GIF"
            : "Converter para GIF";
      }
    }

    // ---- Render: resultados ----
    function ensureResultCard(entry) {
      var card = document.createElement("div");
      card.className = "result-card";
      card.innerHTML =
        '<div class="result-preview"></div>' +
        '<div class="result-body">' +
        '  <div class="result-name"></div>' +
        '  <div class="result-progress"><span></span></div>' +
        '  <div class="result-status">Na fila…</div>' +
        "</div>";
      card.querySelector(".result-name").textContent = entry.file.name;
      resultsEl.appendChild(card);
      return card;
    }

    function setCardProgress(card, pct) {
      card.querySelector(".result-progress > span").style.width = pct + "%";
      card.querySelector(".result-status").textContent = "Convertendo… " + pct + "%";
    }

    function setCardDone(card, entry, result) {
      var url = URL.createObjectURL(result.blob);
      results.push({ name: baseName(entry.file.name) + ".gif", blob: result.blob, url: url });

      var preview = card.querySelector(".result-preview");
      preview.innerHTML = "";
      var img = document.createElement("img");
      img.src = url;
      img.alt = entry.file.name;
      img.loading = "lazy";
      preview.appendChild(img);

      var body = card.querySelector(".result-body");
      body.innerHTML =
        '<div class="result-name"></div>' +
        '<div class="result-meta">' +
        '  <span class="chip">' + result.width + " px</span>" +
        "  <span>" + formatBytes(result.blob.size) + "</span>" +
        "</div>";
      body.querySelector(".result-name").textContent = baseName(entry.file.name) + ".gif";

      var dl = document.createElement("a");
      dl.className = "btn-download";
      dl.href = url;
      dl.download = baseName(entry.file.name) + ".gif";
      dl.textContent = "Baixar GIF";
      body.appendChild(dl);
    }

    function setCardError(card, err) {
      card.querySelector(".result-progress").classList.add("hidden");
      var st = card.querySelector(".result-status");
      st.textContent = "Erro: " + (err && err.message ? err.message : "falha na conversão");
      st.classList.add("is-error");
    }

    // ---- Fluxo principal ----
    async function runConversion() {
      if (converting || files.length === 0) return;
      converting = true;
      results = [];
      resultsEl.innerHTML = "";
      resultsSection.classList.remove("hidden");
      convertBtn.classList.add("is-busy");
      convertBtn.disabled = true;
      convertBtn.querySelector(".btn-label").textContent = "Convertendo…";

      for (var i = 0; i < files.length; i++) {
        var entry = files[i];
        var card = ensureResultCard(entry);
        setCardProgress(card, 0);
        try {
          var result = await convertOne(
            entry,
            (function (c) {
              return function (pct) {
                setCardProgress(c, pct);
              };
            })(card),
            function (s) {
              globalStatus.textContent = s;
            }
          );
          setCardDone(card, entry, result);
        } catch (err) {
          console.error(err);
          setCardError(card, err);
        }
      }

      globalStatus.textContent =
        results.length > 0
          ? "Pronto! " + results.length + " GIF" + (results.length > 1 ? "s" : "") + " gerado" + (results.length > 1 ? "s" : "") + "."
          : "";
      converting = false;
      convertBtn.classList.remove("is-busy");
      updateConvertBtn();
    }

    function downloadAll() {
      if (results.length === 0) return;
      results.forEach(function (r, idx) {
        setTimeout(function () {
          var a = document.createElement("a");
          a.href = r.url;
          a.download = r.name;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
        }, idx * 350);
      });
    }

    // ---- Eventos ----
    fileInput.addEventListener("change", function (e) {
      addFiles(e.target.files);
      fileInput.value = "";
    });

    dropzone.addEventListener("keydown", function (e) {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        fileInput.click();
      }
    });

    ["dragenter", "dragover"].forEach(function (evt) {
      dropzone.addEventListener(evt, function (e) {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.add("is-drag");
      });
    });
    ["dragleave", "drop"].forEach(function (evt) {
      dropzone.addEventListener(evt, function (e) {
        e.preventDefault();
        e.stopPropagation();
        if (evt === "dragleave" && dropzone.contains(e.relatedTarget)) return;
        dropzone.classList.remove("is-drag");
      });
    });
    dropzone.addEventListener("drop", function (e) {
      if (e.dataTransfer && e.dataTransfer.files) {
        addFiles(e.dataTransfer.files);
      }
    });

    presetGrid.addEventListener("click", function (e) {
      var btn = e.target.closest(".preset");
      if (!btn) return;
      selectedPreset = btn.getAttribute("data-preset");
      var all = presetGrid.querySelectorAll(".preset");
      for (var i = 0; i < all.length; i++) {
        var on = all[i] === btn;
        all[i].classList.toggle("is-selected", on);
        all[i].setAttribute("aria-checked", on ? "true" : "false");
      }
    });

    convertBtn.addEventListener("click", runConversion);
    downloadAllBtn.addEventListener("click", downloadAll);

    // estado inicial
    updateConvertBtn();
  })();
</script>
